# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_... / sk_test_...) during development
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# ── Email (Nodemailer SMTP) ─────────────────────────────────────────────────────
# Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=Now Book Store <your@gmail.com>

# ── Store ───────────────────────────────────────────────────────────────────────
STORE_URL=http://localhost:3000
PORT=3000
